WEBWOVEN_ENV=development
WEBWOVEN_ORIGIN=http://localhost:5173
WEBWOVEN_API_ORIGIN=http://localhost:8000
WEBWOVEN_DATABASE_URL=postgresql+asyncpg://webwoven:webwoven@localhost:5432/webwoven
WEBWOVEN_VALKEY_URL=redis://localhost:6379/0
WEBWOVEN_GRAPH_PATH=data/builds/current/graph.sqlite3
WEBWOVEN_GRAPH_MANIFEST_PATH=data/builds/current/manifest.json
WEBWOVEN_GRAPH_DIR=./data/builds/current
WEBWOVEN_SESSION_SECRET=replace-with-at-least-32-random-bytes
WEBWOVEN_EDGE_SECRET=replace-with-a-different-32-byte-secret
WEBWOVEN_COOKIE_SECURE=false
WEBWOVEN_WIKIMEDIA_USER_AGENT=Webwoven/0.1 (https://github.com/Hyperrick/webwoven)
