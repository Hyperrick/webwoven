WEBWOVEN_ENV=production
WEBWOVEN_SITE_ADDRESS=https://webwoven.example.com
WEBWOVEN_REDIRECT_ADDRESS=https://example.com
WEBWOVEN_ANALYTICS_ADDRESS=https://stats.webwoven.example.com
WEBWOVEN_ANALYTICS_WEBSITE_ID=replace-with-a-stable-website-uuid
WEBWOVEN_ANALYTICS_DOMAIN=webwoven.example.com
WEBWOVEN_ORIGIN=https://webwoven.example.com
WEBWOVEN_API_ORIGIN=https://webwoven.example.com
WEBWOVEN_SESSION_SECRET=replace-with-64-hex-characters
WEBWOVEN_EDGE_SECRET=replace-with-a-different-64-hex-secret
WEBWOVEN_COOKIE_SECURE=true
WEBWOVEN_GRAPH_DIR=/opt/webwoven/data/graph-build-id
POSTGRES_PASSWORD=replace-with-a-url-safe-database-password
UMAMI_DATABASE_PASSWORD=replace-with-a-different-url-safe-database-password
UMAMI_APP_SECRET=replace-with-a-64-hex-character-secret
UMAMI_ADMIN_PASSWORD=replace-with-a-unique-dashboard-password
WEBWOVEN_HTTP_PORT=80
WEBWOVEN_HTTPS_PORT=443
WEBWOVEN_ANALYTICS_PORT=3000
